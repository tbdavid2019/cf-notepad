name = "cloud-notepad"
main = "src/index.js"
compatibility_date = "2023-10-25"

kv_namespaces = [
  { binding = "NOTES", id = "創建後取回ID" },
  { binding = "SHARE", id = "創建後取回ID" }
]

[assets]
directory = "./static"

[vars]
SCN_APP_NAME = "david888 wiki"
SCN_SALT = "random string for salt 例如 25A39F3A-BA6E-4ED3-9E5B-3FDC8A8B2406 "
SCN_SECRET = "random string for jwt secret 例如 10BD2ACC-CD16-4218-A92D-CA808D682CFF"
SCN_ADMIN_PATH = "/admin"
SCN_ADMIN_PW = "admin-password"
SCN_SLUG_LENGTH = "3"
SCN_ENABLE_R2 = "0"
SCN_R2_DOMAIN = "https://your-r2-domain.com"
SCN_GA_MEASUREMENT_ID = "G-XXXXXXXXXX"
SCN_ENABLE_WEBTALK = "0"
# Optional Webtalk widget overrides. Set SCN_ENABLE_WEBTALK = "1" to load the widget on Share pages.
# SCN_WEBTALK_SCRIPT_URL = "https://webtalk-nine.vercel.app/webtalk.js"
# SCN_WEBTALK_SCOPE = "meta"
# SCN_WEBTALK_SITE_ID = "david888-wiki"
# SCN_WEBTALK_AI_ENDPOINT = "https://webtalk-nine.vercel.app/api/webtalk/ai"
SCN_ENABLE_NOTE_HISTORY = "0"
SCN_NOTE_HISTORY_LIMIT = "10"
SCN_NOTE_HISTORY_MIN_INTERVAL_SECONDS = "300"

# [[r2_buckets]]
# binding = "IMAGES"
# bucket_name = "<YOUR_BUCKET_NAME>"

# [[d1_databases]]
# binding = "NOTE_HISTORY_DB"
# database_name = "cloud-notepad-history"
# database_id = "<YOUR_D1_DATABASE_ID>"

# Cron trigger: Daily cleanup at 9 AM Taiwan time (1 AM UTC)
[triggers]
crons = ["0 1 * * *"]
